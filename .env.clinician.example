POSTGRES_USER=holisticare
POSTGRES_PASSWORD=changeme
POSTGRES_DB=holisticare_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# At least one provider key is required for AI generation.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

CLAUDE_MODEL=claude-sonnet-4-20250514
RAG_LLM_FALLBACK_OPENAI=true
OPENAI_CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536

CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=20
TOP_K_FINAL=8
NUM_QUERY_VARIANTS=4
MIN_EVIDENCE_LEVEL=B

RERANKER_BACKEND=crossencoder
CROSSENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

DEBUG=true
SECRET_KEY=replace-with-a-random-secret
CORS_ORIGINS=http://localhost:5173
ALLOW_DEV_AUTH=true

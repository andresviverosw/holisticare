# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=holisticare
POSTGRES_PASSWORD=changeme
POSTGRES_DB=holisticare_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── LLM ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Embeddings ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536

# ─── RAG ─────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=20         # candidates per query before rerank
TOP_K_FINAL=8              # chunks passed to LLM after rerank
NUM_QUERY_VARIANTS=4       # multi-query expansion count
MIN_EVIDENCE_LEVEL=B       # A | B | C | expert_opinion

# ─── Reranker ─────────────────────────────────────────────────
RERANKER_BACKEND=crossencoder          # crossencoder | cohere
CROSSENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# COHERE_API_KEY=...                   # only needed if RERANKER_BACKEND=cohere

# ─── App ──────────────────────────────────────────────────────
DEBUG=true
SECRET_KEY=changeme-generate-a-real-one
CORS_ORIGINS=http://localhost:5173
# Local Docker / SPA testing: set true only in non-production environments.
# Production / staging: MUST be false (dev login route is not registered).
ALLOW_DEV_AUTH=true

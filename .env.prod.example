# HolistiCare production env template (US-OPS-PROD-COMPOSE)
# Copy to `.env.prod` on the server (mode 600). NEVER commit `.env.prod`.
# Replace every changeme / placeholder before go-live.

# ─── Database (managed Postgres + pgvector, e.g. Neon) ────────
POSTGRES_USER=replace-me
POSTGRES_PASSWORD=generate-a-strong-password
POSTGRES_DB=holisticare
POSTGRES_HOST=ep-xxxx-pooler.region.aws.neon.tech
POSTGRES_PORT=5432
# Require TLS to managed Postgres (asyncpg query param ssl=require)
POSTGRES_SSL_REQUIRE=true

# ─── LLM / embeddings ─────────────────────────────────────────
ANTHROPIC_API_KEY=replace-me
CLAUDE_MODEL=claude-sonnet-4-20250514
RAG_LLM_FALLBACK_OPENAI=true
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_API_KEY=replace-me
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536

# ─── RAG ──────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=20
TOP_K_FINAL=8
NUM_QUERY_VARIANTS=4
MIN_EVIDENCE_LEVEL=B
RERANKER_BACKEND=crossencoder
CROSSENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ─── App (production contract) ────────────────────────────────
DEBUG=false
SECRET_KEY=changeme-generate-a-real-one
# SPA origin only (Cloudflare Pages / static host) — not *
CORS_ORIGINS=https://app.example.com
# Compose overlay also forces ALLOW_DEV_AUTH=false; keep false here too.
ALLOW_DEV_AUTH=false

# Patient invite absolute links (must match the public SPA origin)
PUBLIC_APP_BASE_URL=https://app.example.com
DIARY_INVITE_TTL_HOURS=168
PATIENT_JWT_TTL_HOURS=720
CLINICIAN_JWT_TTL_HOURS=8

# Seed once after schema is applied (do not leave weak passwords):
# SEED_CLINICIAN_USERNAME=clinician
# SEED_CLINICIAN_PASSWORD=generate-a-strong-password
# SEED_CLINICIAN_ROLE=admin
